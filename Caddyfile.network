{
    admin localhost:2019
    skip_install_trust
}

# Network access (iPad/andere Geräte)
https://192.168.178.44:8443 {
    tls internal
    reverse_proxy localhost:8080
}

# Localhost access
https://127.0.0.1:8443 {
    tls internal
    reverse_proxy localhost:8080
}

# HTTP Redirect (localhost)
http://127.0.0.1:8001 {
    redir https://127.0.0.1:8443{uri} permanent
}

# HTTP Redirect (network)
http://192.168.178.44:8001 {
    redir https://192.168.178.44:8443{uri} permanent
}
