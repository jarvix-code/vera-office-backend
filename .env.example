# VERA Office - Environment Variables
# Copy this file to .env and fill in your values

# ============================================================================
# FAST LLM (Cloud) - User-facing Tasks (Chat, Onboarding)
# ============================================================================
# Boris' Vision: Hybrid-LLM-Setup
# - Fast Cloud (GPT-4o-mini) for user-facing tasks (< 1s response)
# - Local (Mistral 7B) for background tasks (30s+ acceptable)
# 
# If FAST_LLM_API_KEY is NOT set:
# - All tasks will use Local LLM (offline-first)
# - Chat will fallback to Local LLM (slower but works offline)
#
# Provider Options: "openai" (primary) | "anthropic" (future)
FAST_LLM_PROVIDER=openai
FAST_LLM_MODEL=gpt-4o-mini
FAST_LLM_API_KEY=

# OpenAI API Key (alternative way to set it)
# Get your key from: https://platform.openai.com/api-keys
OPENAI_API_KEY=

# ============================================================================
# AUTH (JWT)
# ============================================================================
SECRET_KEY=VERA-OFFICE-SECRET-CHANGE-IN-PRODUCTION-PLEASE

# ============================================================================
# DATABASE
# ============================================================================
DATABASE_URL=sqlite:///data/vera.db

# ============================================================================
# TELEGRAM (Feedback Bot)
# ============================================================================
TELEGRAM_BOT_TOKEN=

# ============================================================================
# DEVICE IDENTITY
# ============================================================================
# Auto-generated during installation - do not change manually
DEVICE_ID=

# ============================================================================
# UPDATE SERVER
# ============================================================================
UPDATE_SERVER=https://updates.vera-office.de
AUTO_UPDATE=true

# ============================================================================
# DEVELOPMENT
# ============================================================================
DEBUG=true
LOG_LEVEL=DEBUG
