[req]
default_bits = 2048
prompt = no
default_md = sha256
distinguished_name = dn
req_extensions = v3_req

[dn]
C=DE
O=VERA Office
CN=vera-office.local

[v3_req]
subjectAltName = @alt_names

[alt_names]
DNS.1 = vera-office.local
DNS.2 = 192.168.178.44
DNS.3 = localhost
IP.1 = 192.168.178.44
IP.2 = 127.0.0.1
